{
  "name": "brainreact",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "postinstall": "node scripts/install-web.mjs",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:api": "node scripts/run-api-dev.mjs",
    "build:web": "npm run build --prefix apps/web",
    "lint:web": "npm run lint --prefix apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
